public class SlotToIndexUC4 {

    // Method to convert slot to row and column
    public static int[] convertSlotToIndex(int slot) {
        int index = slot - 1;   // convert to 0-based index

        int row = index / 3;    // division gives row
        int col = index % 3;    // modulo gives column

        return new int[]{row, col}; // return both values
    }

    public static void main(String[] args) {
        int slot = 5; // Example input

        int[] result = convertSlotToIndex(slot);

        System.out.println("Slot: " + slot);
        System.out.println("Row: " + result[0]);
        System.out.println("Column: " + result[1]);
    }
}
