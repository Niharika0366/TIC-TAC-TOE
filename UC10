public boolean checkDraw(char[][] board) {

    // Traverse entire board
    for (int i = 0; i < board.length; i++) {

        for (int j = 0; j < board[i].length; j++) {

            // If any cell is empty → not a draw
            if (board[i][j] == ' ') {
                return false;
            }
        }
    }

    // No empty cells → draw
    return true;
}
